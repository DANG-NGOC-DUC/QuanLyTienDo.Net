<UserControl x:Class="WorkProgressManagement.Views.Pages.DashboardPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WorkProgressManagement.Views.Pages"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="{StaticResource BackgroundBrush}">

        <StackPanel>

            <TextBlock Text="Dashboard"
                   Style="{StaticResource TitleTextStyle}"
                   Margin="0,0,0,20"/>

            <WrapPanel>

                <Border Style="{StaticResource CardStyle}" Width="220" Height="120">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="12" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="Projects" Style="{StaticResource BodyTextStyle}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}" Width="220" Height="120">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="35" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="Tasks" Style="{StaticResource BodyTextStyle}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}" Width="220" Height="120">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="8" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="Users" Style="{StaticResource BodyTextStyle}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

            </WrapPanel>

        </StackPanel>

    </Grid>
</UserControl>
