<UserControl x:Class="WorkProgressManagement.Views.Pages.ProfilePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WorkProgressManagement.Views.Pages"
             mc:Ignorable="d" 
             d:DesignHeight="650" d:DesignWidth="950"
             Background="{StaticResource BackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="Hồ sơ cá nhân" Style="{StaticResource TitleTextStyle}"/>
                <TextBlock Text="Quản lý thông tin định danh, địa chỉ liên hệ và bảo mật tài khoản." 
                           Style="{StaticResource BodyTextStyle}" Margin="0,4,0,0"/>
            </StackPanel>

            <Grid Grid.Row="1" Margin="-8,0,-8,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3.5*"/>
                    <ColumnDefinition Width="6.5*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardStyle}" VerticalAlignment="Top">
                    <StackPanel HorizontalAlignment="Center" Margin="0,16,0,16">

                        <Border Width="96" Height="96" CornerRadius="48" Background="{StaticResource PrimaryBrush}" 
                                HorizontalAlignment="Center" Margin="0,0,0,16">
                            <TextBlock Text="Đ" Foreground="White" FontSize="36" FontWeight="Bold" 
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <TextBlock Text="Hà Xuân Đại" Style="{StaticResource SubtitleTextStyle}" FontSize="18" HorizontalAlignment="Center"/>
                        <TextBlock Text="daihx" Style="{StaticResource BodyTextStyle}" HorizontalAlignment="Center" Margin="0,2,0,12"/>

                        <Border Background="#EEF2FF" CornerRadius="4" Padding="12,4" HorizontalAlignment="Center" Margin="0,0,0,24">
                            <TextBlock Text="Admin" FontSize="12" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                        </Border>

                        <Border Height="1" Width="200" Background="{StaticResource BorderBrush}" Margin="0,0,0,20"/>

                        <Grid Width="200" Margin="0,0,0,12">
                            <TextBlock Text="Ngày tham gia:" Style="{StaticResource BodyTextStyle}"/>
                            <TextBlock Text="12/01/2026" Style="{StaticResource BodyTextStyle}" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Right"/>
                        </Grid>

                        <Grid Width="200" Margin="0,0,0,12">
                            <TextBlock Text="Dự án đang tham gia:" Style="{StaticResource BodyTextStyle}"/>
                            <TextBlock Text="03" Style="{StaticResource BodyTextStyle}" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Right"/>
                        </Grid>

                        <Grid Width="200">
                            <TextBlock Text="Việc đang xử lý:" Style="{StaticResource BodyTextStyle}"/>
                            <TextBlock Text="04" Style="{StaticResource BodyTextStyle}" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Right"/>
                        </Grid>

                    </StackPanel>
                </Border>

                <StackPanel Grid.Column="1">

                    <Border Style="{StaticResource CardStyle}" Margin="8,8,8,16">
                        <StackPanel>
                            <TextBlock Text="Thông tin chung" Style="{StaticResource SubtitleTextStyle}" Margin="0,0,0,16"/>

                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="Tên đăng nhập" Style="{StaticResource BodyTextStyle}" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                                    <TextBox Text="daihx" Style="{StaticResource DefaultTextBoxStyle}" IsReadOnly="True" Background="#F9FAFB" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                    <TextBlock Text="Vai trò hệ thống" Style="{StaticResource BodyTextStyle}" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                                    <TextBox Text="Admin" Style="{StaticResource DefaultTextBoxStyle}" IsReadOnly="True" Background="#F9FAFB" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Họ và tên" Style="{StaticResource BodyTextStyle}" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                            <TextBox Text="Hà Xuân Đại" Style="{StaticResource DefaultTextBoxStyle}" Margin="0,0,0,16"/>

                            <TextBlock Text="Địa chỉ Email" Style="{StaticResource BodyTextStyle}" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                            <TextBox Text="dai@phenikaa.edu.vn" Style="{StaticResource DefaultTextBoxStyle}" Margin="0,0,0,20"/>

                            <Button Content="Lưu thay đổi thông tin" Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Right"/>
                        </StackPanel>
                    </Border>


                    <Border Style="{StaticResource CardStyle}" Margin="8,0,8,8">
                        <StackPanel>
                            <TextBlock Text="Bảo mật &amp; Mật khẩu" Style="{StaticResource SubtitleTextStyle}" Margin="0,0,0,6"/>
                            <TextBlock Text="Để bảo vệ tài khoản, tuyệt đối không chia sẻ mật khẩu cho người khác." Style="{StaticResource BodyTextStyle}" FontSize="12" Margin="0,0,0,16"/>

                            <TextBlock Text="Mật khẩu hiện tại" Style="{StaticResource BodyTextStyle}" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                            <PasswordBox Height="36" Padding="10,5" FontSize="14" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="0,0,0,16"/>

                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="Mật khẩu mới" Style="{StaticResource BodyTextStyle}" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                                    <PasswordBox Height="36" Padding="10,5" FontSize="14" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                    <TextBlock Text="Xác nhận mật khẩu mới" Style="{StaticResource BodyTextStyle}" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                                    <PasswordBox Height="36" Padding="10,5" FontSize="14" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"/>
                                </StackPanel>
                            </Grid>

                            <Button Content="Cập nhật mật khẩu mới" Style="{StaticResource SecondaryButtonStyle}" 
                                    Foreground="{StaticResource DangerBrush}" BorderBrush="{StaticResource DangerBrush}" 
                                    HorizontalAlignment="Right"/>
                        </StackPanel>
                    </Border>

                </StackPanel>

            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>