<Window x:Class="WorkProgressManagement.Views.Pages.Login"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Đăng nhập" Height="480" Width="400"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent">

    <Border Background="White" CornerRadius="8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.06" Color="Black"/>
        </Border.Effect>

        <Grid Margin="36,24,36,32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Button Grid.Row="0" Content="✕" Width="28" Height="28" HorizontalAlignment="Right" Margin="0,0,-16,0"
                    Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextSecondaryBrush}" Cursor="Hand"/>

            <StackPanel Grid.Row="1" Margin="0,10,0,32" HorizontalAlignment="Center">
                <TextBlock Text="Đăng Nhập" Style="{StaticResource TitleTextStyle}" HorizontalAlignment="Center"/>
                <TextBlock Text="Work Progress Management" Style="{StaticResource BodyTextStyle}" Margin="0,4,0,0" HorizontalAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Row="2">

                <TextBlock Text="Tài khoản" Style="{StaticResource BodyTextStyle}" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                <TextBox Style="{StaticResource DefaultTextBoxStyle}" 
                         Tag="Nhập username..." TextChanged="TextBox_TextChanged"/>

                <Grid Margin="0,16,0,6">
                    <TextBlock Text="Mật khẩu" Style="{StaticResource BodyTextStyle}" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Left"/>
                    <TextBlock Text="Quên mật khẩu?" Style="{StaticResource BodyTextStyle}" FontSize="12" Foreground="{StaticResource PrimaryBrush}" Cursor="Hand" HorizontalAlignment="Right"/>
                </Grid>
                <PasswordBox Height="36" Padding="10,5" FontSize="14" 
                             Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"/>

                <CheckBox Content="Ghi nhớ đăng nhập" Style="{StaticResource BodyTextStyle}" Margin="0,16,0,0"/>

            </StackPanel>

            <Button Grid.Row="3" Content="Vào hệ thống" Style="{StaticResource PrimaryButtonStyle}" Margin="0,32,0,0">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6"/>
                    </Style>
                </Button.Resources>
            </Button>

        </Grid>
    </Border>
</Window>