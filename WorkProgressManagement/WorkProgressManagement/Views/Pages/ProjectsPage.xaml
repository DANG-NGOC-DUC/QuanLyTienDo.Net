<UserControl x:Class="WorkProgressManagement.Views.Pages.ProjectsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WorkProgressManagement.Views.Pages"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Danh sách Dự án" Style="{StaticResource TitleTextStyle}"/>
                    <TextBlock Text="Quản lý tổng quan tiến độ, thời hạn và thành viên tham gia các dự án." 
                               Style="{StaticResource BodyTextStyle}" Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBox Width="240" Margin="0,0,12,0" 
                             Style="{StaticResource DefaultTextBoxStyle}" 
                             Tag="Tìm kiếm dự án..."/>

                    <Button Content="+ Tạo dự án mới" Style="{StaticResource PrimaryButtonStyle}"/>
                </StackPanel>
            </Grid>

            <WrapPanel Grid.Row="1" Margin="-8">

                <Border Style="{StaticResource CardStyle}" Width="280">
                    <StackPanel>
                        <Border HorizontalAlignment="Left" CornerRadius="4" Padding="8,4" 
                                Background="{StaticResource PrimaryBrush}" Margin="0,0,0,12">
                            <TextBlock Text="Đang triển khai" FontSize="11" FontWeight="Bold" Foreground="White"/>
                        </Border>

                        <TextBlock Text="Hệ thống Quản lý Nhà hàng" Style="{StaticResource SubtitleTextStyle}" TextWrapping="Wrap"/>

                        <TextBlock Text="Xây dựng nền tảng đặt món qua QR Code và quản lý chuỗi cung ứng bếp." 
                                   Style="{StaticResource BodyTextStyle}" 
                                   Margin="0,8,0,16" Height="40" TextWrapping="Wrap" TextTrimming="CharacterEllipsis"/>

                        <Grid Margin="0,0,0,12">
                            <TextBlock Text="Quản lý: Đại" Style="{StaticResource BodyTextStyle}" HorizontalAlignment="Left"/>
                            <TextBlock Text="Hạn: 30/05" Style="{StaticResource BodyTextStyle}" HorizontalAlignment="Right"/>
                        </Grid>

                        <Grid Margin="0,0,0,16">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Tiến độ tổng thể" Style="{StaticResource BodyTextStyle}" FontSize="12"/>
                            <TextBlock Grid.Row="0" Text="75%" Style="{StaticResource SubtitleTextStyle}" FontSize="12" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Right"/>

                            <Grid Grid.Row="1" Margin="0,6,0,0">
                                <Border Height="6" Background="{StaticResource BorderBrush}" CornerRadius="3"/>
                                <Border Height="6" Width="185" HorizontalAlignment="Left" Background="{StaticResource PrimaryBrush}" CornerRadius="3"/>
                            </Grid>
                        </Grid>

                        <Button Content="Xem chi tiết công việc →" Style="{StaticResource SecondaryButtonStyle}" Height="34" FontSize="13"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}" Width="280">
                    <StackPanel>
                        <Border HorizontalAlignment="Left" CornerRadius="4" Padding="8,4" 
                                Background="{StaticResource WarningBrush}" Margin="0,0,0,12">
                            <TextBlock Text="Sắp tới hạn" FontSize="11" FontWeight="Bold" Foreground="White"/>
                        </Border>

                        <TextBlock Text="Ứng dụng Gia phả dòng họ" Style="{StaticResource SubtitleTextStyle}" TextWrapping="Wrap"/>

                        <TextBlock Text="Thiết kế cây phả hệ tương tác, lưu trữ hồ sơ thành viên và phê duyệt thông tin." 
                                   Style="{StaticResource BodyTextStyle}" 
                                   Margin="0,8,0,16" Height="40" TextWrapping="Wrap" TextTrimming="CharacterEllipsis"/>

                        <Grid Margin="0,0,0,12">
                            <TextBlock Text="Quản lý: Quân" Style="{StaticResource BodyTextStyle}" HorizontalAlignment="Left"/>
                            <TextBlock Text="Hạn: Hôm nay" Style="{StaticResource BodyTextStyle}" Foreground="{StaticResource WarningBrush}" FontWeight="Bold" HorizontalAlignment="Right"/>
                        </Grid>

                        <Grid Margin="0,0,0,16">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Tiến độ tổng thể" Style="{StaticResource BodyTextStyle}" FontSize="12"/>
                            <TextBlock Grid.Row="0" Text="40%" Style="{StaticResource SubtitleTextStyle}" FontSize="12" Foreground="{StaticResource WarningBrush}" HorizontalAlignment="Right"/>

                            <Grid Grid.Row="1" Margin="0,6,0,0">
                                <Border Height="6" Background="{StaticResource BorderBrush}" CornerRadius="3"/>
                                <Border Height="6" Width="100" HorizontalAlignment="Left" Background="{StaticResource WarningBrush}" CornerRadius="3"/>
                            </Grid>
                        </Grid>

                        <Button Content="Xem chi tiết công việc →" Style="{StaticResource SecondaryButtonStyle}" Height="34" FontSize="13"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}" Width="280">
                    <StackPanel>
                        <Border HorizontalAlignment="Left" CornerRadius="4" Padding="8,4" 
                                Background="{StaticResource SuccessBrush}" Margin="0,0,0,12">
                            <TextBlock Text="Đã nghiệm thu" FontSize="11" FontWeight="Bold" Foreground="White"/>
                        </Border>

                        <TextBlock Text="Hệ thống FocusFlow AI" Style="{StaticResource SubtitleTextStyle}" TextWrapping="Wrap"/>

                        <TextBlock Text="Ứng dụng quản lý công việc cá nhân bằng giọng nói và lập lịch tự động bằng AI." 
                                   Style="{StaticResource BodyTextStyle}" 
                                   Margin="0,8,0,16" Height="40" TextWrapping="Wrap" TextTrimming="CharacterEllipsis"/>

                        <Grid Margin="0,0,0,12">
                            <TextBlock Text="Quản lý: Đức" Style="{StaticResource BodyTextStyle}" HorizontalAlignment="Left"/>
                            <TextBlock Text="Hạn: 15/04" Style="{StaticResource BodyTextStyle}" HorizontalAlignment="Right"/>
                        </Grid>

                        <Grid Margin="0,0,0,16">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Tiến độ tổng thể" Style="{StaticResource BodyTextStyle}" FontSize="12"/>
                            <TextBlock Grid.Row="0" Text="100%" Style="{StaticResource SubtitleTextStyle}" FontSize="12" Foreground="{StaticResource SuccessBrush}" HorizontalAlignment="Right"/>

                            <Grid Grid.Row="1" Margin="0,6,0,0">
                                <Border Height="6" Background="{StaticResource BorderBrush}" CornerRadius="3"/>
                                <Border Height="6" Width="246" HorizontalAlignment="Left" Background="{StaticResource SuccessBrush}" CornerRadius="3"/>
                            </Grid>
                        </Grid>

                        <Button Content="Xem lại lưu trữ →" Style="{StaticResource SecondaryButtonStyle}" Height="34" FontSize="13"/>
                    </StackPanel>
                </Border>

            </WrapPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
