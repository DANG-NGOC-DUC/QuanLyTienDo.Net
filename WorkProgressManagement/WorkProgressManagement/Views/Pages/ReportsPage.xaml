<UserControl x:Class="WorkProgressManagement.Views.Pages.ReportsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WorkProgressManagement.Views.Pages"
             mc:Ignorable="d" 
             d:DesignHeight="680" d:DesignWidth="1000"
             Background="{StaticResource BackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Báo cáo &amp; Thống kê" Style="{StaticResource TitleTextStyle}"/>
                    <TextBlock Text="Số liệu tổng hợp hiệu suất làm việc và tình trạng hoàn thành các dự án." 
                               Style="{StaticResource BodyTextStyle}" Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <ComboBox Width="150" Margin="0,0,12,0" Style="{StaticResource DefaultComboBoxStyle}">
                        <ComboBoxItem Content="Tháng này" IsSelected="True"/>
                        <ComboBoxItem Content="Quý này (Q2)"/>
                        <ComboBoxItem Content="Toàn bộ thời gian"/>
                    </ComboBox>

                    <Button Content="↓ Xuất báo cáo (PDF)" Style="{StaticResource SecondaryButtonStyle}"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Margin="-8,0,-8,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="TỔNG DỰ ÁN" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Text="04" Style="{StaticResource TitleTextStyle}" FontSize="26" Margin="0,8,0,0"/>
                        <TextBlock Text="Đang chạy 100%" FontSize="12" Foreground="{StaticResource SuccessBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="TỔNG CÔNG VIỆC" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Text="28" Style="{StaticResource TitleTextStyle}" FontSize="26" Margin="0,8,0,0"/>
                        <TextBlock Text="Đã giao cho thành viên" Style="{StaticResource BodyTextStyle}" FontSize="12" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="TỶ LỆ HOÀN THÀNH" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Text="82%" Style="{StaticResource TitleTextStyle}" FontSize="26" Foreground="{StaticResource SuccessBrush}" Margin="0,8,0,0"/>
                        <TextBlock Text="↑ Tăng 5% so với tháng trước" FontSize="12" Foreground="{StaticResource SuccessBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="CÔNG VIỆC QUÁ HẠN" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Text="02" Style="{StaticResource TitleTextStyle}" FontSize="26" Foreground="{StaticResource DangerBrush}" Margin="0,8,0,0"/>
                        <TextBlock Text="Cần đôn đốc nghiệm thu ngay" FontSize="12" Foreground="{StaticResource DangerBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Grid.Row="2" Margin="-8,0,-8,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="6*"/>
                    <ColumnDefinition Width="4*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Phân bổ trạng thái công việc" Style="{StaticResource SubtitleTextStyle}" Margin="0,0,0,20"/>

                        <Grid Margin="0,0,0,16">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,6">
                                <TextBlock Text="Hoàn thành (Done)" Style="{StaticResource BodyTextStyle}" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="18 việc (64%)" Style="{StaticResource BodyTextStyle}" HorizontalAlignment="Right"/>
                            </Grid>

                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="64*"/>
                                    <ColumnDefinition Width="36*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.ColumnSpan="2" Height="8" Background="{StaticResource BorderBrush}" CornerRadius="4"/>
                                <Border Grid.Column="0" Height="8" Background="{StaticResource SuccessBrush}" CornerRadius="4"/>
                            </Grid>
                        </Grid>

                        <Grid Margin="0,0,0,16">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,6">
                                <TextBlock Text="Đang triển khai (In Progress)" Style="{StaticResource BodyTextStyle}" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="6 việc (21%)" Style="{StaticResource BodyTextStyle}" HorizontalAlignment="Right"/>
                            </Grid>

                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="21*"/>
                                    <ColumnDefinition Width="79*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.ColumnSpan="2" Height="8" Background="{StaticResource BorderBrush}" CornerRadius="4"/>
                                <Border Grid.Column="0" Height="8" Background="{StaticResource PrimaryBrush}" CornerRadius="4"/>
                            </Grid>
                        </Grid>

                        <Grid Margin="0,0,0,16">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,6">
                                <TextBlock Text="Chờ phê duyệt (Pending Review)" Style="{StaticResource BodyTextStyle}" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="2 việc (7%)" Style="{StaticResource BodyTextStyle}" HorizontalAlignment="Right"/>
                            </Grid>

                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="7*"/>
                                    <ColumnDefinition Width="93*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.ColumnSpan="2" Height="8" Background="{StaticResource BorderBrush}" CornerRadius="4"/>
                                <Border Grid.Column="0" Height="8" Background="{StaticResource WarningBrush}" CornerRadius="4"/>
                            </Grid>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,6">
                                <TextBlock Text="Chưa làm (To Do)" Style="{StaticResource BodyTextStyle}" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="2 việc (8%)" Style="{StaticResource BodyTextStyle}" HorizontalAlignment="Right"/>
                            </Grid>

                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="8*"/>
                                    <ColumnDefinition Width="92*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.ColumnSpan="2" Height="8" Background="{StaticResource BorderBrush}" CornerRadius="4"/>
                                <Border Grid.Column="0" Height="8" Background="{StaticResource TextSecondaryBrush}" CornerRadius="4"/>
                            </Grid>
                        </Grid>

                    </StackPanel>
                </Border>


                <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Hiệu suất thành viên tuần này" Style="{StaticResource SubtitleTextStyle}" Margin="0,0,0,20"/>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Width="38" Height="38" CornerRadius="19" Background="{StaticResource PrimaryBrush}" Margin="0,0,12,0">
                                <TextBlock Text="Đ" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14"/>
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Hà Xuân Đại" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"/>
                                <TextBlock Text="12 việc đã đóng" Style="{StaticResource BodyTextStyle}" FontSize="12" Margin="0,2,0,0"/>
                            </StackPanel>

                            <Border Grid.Column="2" Background="#ECFDF5" CornerRadius="12" Padding="8,4" VerticalAlignment="Center">
                                <TextBlock Text="98 pts" FontSize="11" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}"/>
                            </Border>
                        </Grid>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Width="38" Height="38" CornerRadius="19" Background="{StaticResource SuccessBrush}" Margin="0,0,12,0">
                                <TextBlock Text="Đ" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14"/>
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Đặng Ngọc Đức" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"/>
                                <TextBlock Text="10 việc đã đóng" Style="{StaticResource BodyTextStyle}" FontSize="12" Margin="0,2,0,0"/>
                            </StackPanel>

                            <Border Grid.Column="2" Background="#ECFDF5" CornerRadius="12" Padding="8,4" VerticalAlignment="Center">
                                <TextBlock Text="85 pts" FontSize="11" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}"/>
                            </Border>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Width="38" Height="38" CornerRadius="19" Background="{StaticResource WarningBrush}" Margin="0,0,12,0">
                                <TextBlock Text="Q" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14"/>
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Hoàng Minh Quân" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"/>
                                <TextBlock Text="6 việc đã đóng" Style="{StaticResource BodyTextStyle}" FontSize="12" Margin="0,2,0,0"/>
                            </StackPanel>

                            <Border Grid.Column="2" Background="#FFFBEB" CornerRadius="12" Padding="8,4" VerticalAlignment="Center">
                                <TextBlock Text="60 pts" FontSize="11" FontWeight="Bold" Foreground="{StaticResource WarningBrush}"/>
                            </Border>
                        </Grid>

                    </StackPanel>
                </Border>

            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>