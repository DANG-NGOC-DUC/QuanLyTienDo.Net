<UserControl x:Class="WorkProgressManagement.Views.Pages.TasksPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WorkProgressManagement.Views.Pages"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Bảng Công việc" Style="{StaticResource TitleTextStyle}"/>
                <TextBlock Text="Theo dõi, cập nhật trạng thái và phê duyệt các đầu việc được giao." Style="{StaticResource BodyTextStyle}" Margin="0,4,0,0"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <ComboBox Width="150" Margin="0,0,12,0" Style="{StaticResource DefaultComboBoxStyle}">
                    <ComboBoxItem Content="Tất cả dự án" IsSelected="True"/>
                    <ComboBoxItem Content="HT Nhà hàng"/>
                    <ComboBoxItem Content="App Gia phả"/>
                </ComboBox>

                <TextBox Width="200" Margin="0,0,12,0" Style="{StaticResource DefaultTextBoxStyle}" Tag="Tìm tên công việc..."/>
                <Button Content="+ Giao việc mới" Style="{StaticResource PrimaryButtonStyle}"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="5.5*"/>
                <ColumnDefinition Width="4.5*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="0,0,12,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                    <Button Content="Tất cả (12)" Style="{StaticResource PrimaryButtonStyle}" Height="30" Padding="12,0" FontSize="12" Margin="0,0,8,0"/>
                    <Button Content="Của tôi (4)" Style="{StaticResource SecondaryButtonStyle}" Height="30" Padding="12,0" FontSize="12" Margin="0,0,8,0"/>
                    <Button Content="Chờ duyệt (2)" Style="{StaticResource SecondaryButtonStyle}" Height="30" Padding="12,0" FontSize="12" Foreground="{StaticResource WarningBrush}"/>
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="-8">

                        <Border Style="{StaticResource CardStyle}" BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="1.5">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <CheckBox Grid.Column="0" VerticalAlignment="Top" Margin="0,2,12,0"/>

                                <StackPanel Grid.Column="1">
                                    <Grid Margin="0,0,0,6">
                                        <TextBlock Text="Thiết kế Database Schema cho Module Task" Style="{StaticResource SubtitleTextStyle}" FontSize="14"/>
                                        <Border HorizontalAlignment="Right" Background="{StaticResource PrimaryBrush}" CornerRadius="3" Padding="6,2">
                                            <TextBlock Text="In Progress" FontSize="10" Foreground="White" FontWeight="Bold"/>
                                        </Border>
                                    </Grid>

                                    <TextBlock Text="Dự án: Hệ thống Quản lý Nhà hàng" Style="{StaticResource BodyTextStyle}" FontSize="12" Margin="0,0,0,8"/>

                                    <Grid>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                            <Border Width="22" Height="22" CornerRadius="11" Background="{StaticResource TextSecondaryBrush}">
                                                <TextBlock Text="Đ" Foreground="White" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="Đại" Style="{StaticResource BodyTextStyle}" FontSize="12" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <TextBlock Text="Hạn: 30/05" Style="{StaticResource BodyTextStyle}" FontSize="12" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0" VerticalAlignment="Top" Margin="0,2,12,0"/>

                                <StackPanel Grid.Column="1">
                                    <Grid Margin="0,0,0,6">
                                        <TextBlock Text="Rà soát lại tài liệu Use Case hệ thống" Style="{StaticResource SubtitleTextStyle}" FontSize="14"/>
                                        <Border HorizontalAlignment="Right" Background="{StaticResource WarningBrush}" CornerRadius="3" Padding="6,2">
                                            <TextBlock Text="Chờ duyệt" FontSize="10" Foreground="White" FontWeight="Bold"/>
                                        </Border>
                                    </Grid>

                                    <TextBlock Text="Dự án: FocusFlow AI" Style="{StaticResource BodyTextStyle}" FontSize="12" Margin="0,0,0,8"/>

                                    <Grid>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                            <Border Width="22" Height="22" CornerRadius="11" Background="{StaticResource DangerBrush}">
                                                <TextBlock Text="Q" Foreground="White" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="Quân" Style="{StaticResource BodyTextStyle}" FontSize="12" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock Text="Hạn: Hôm qua" Foreground="{StaticResource DangerBrush}" FontSize="12" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource CardStyle}" Opacity="0.6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0" IsChecked="True" VerticalAlignment="Top" Margin="0,2,12,0"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Tạo Repo Github và cấu trúc MVVM" TextDecorations="Strikethrough" Style="{StaticResource SubtitleTextStyle}" FontSize="14"/>
                                    <TextBlock Text="Dự án: Tất cả" Style="{StaticResource BodyTextStyle}" FontSize="12" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Grid>


            <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="4,0,0,0" Background="White">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>

                        <Grid Margin="0,0,0,16">
                            <StackPanel Orientation="Horizontal">
                                <Border Background="{StaticResource PrimaryBrush}" CornerRadius="3" Padding="6,2" Margin="0,0,8,0">
                                    <TextBlock Text="In Progress" FontSize="11" Foreground="White" FontWeight="Bold"/>
                                </Border>
                                <Border Background="#FEE2E2" CornerRadius="3" Padding="6,2">
                                    <TextBlock Text="Ưu tiên cao" FontSize="11" Foreground="{StaticResource DangerBrush}" FontWeight="Bold"/>
                                </Border>
                            </StackPanel>

                            <Button Content="✕" HorizontalAlignment="Right" Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextSecondaryBrush}" Cursor="Hand"/>
                        </Grid>

                        <TextBlock Text="Thiết kế Database Schema cho Module Task" Style="{StaticResource TitleTextStyle}" FontSize="18" TextWrapping="Wrap"/>

                        <Grid Margin="0,16,0,16">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,12">
                                <TextBlock Text="NGƯỜI THỰC HIỆN" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Text="Hà Xuân Đại" Style="{StaticResource SubtitleTextStyle}" FontSize="13" Margin="0,2,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,12">
                                <TextBlock Text="HẠN HOÀN THÀNH" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Text="30/05/2026 (Còn 2 ngày)" Style="{StaticResource SubtitleTextStyle}" FontSize="13" Foreground="{StaticResource PrimaryBrush}" Margin="0,2,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="0">
                                <TextBlock Text="DỰ ÁN" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Text="HT Nhà hàng" Style="{StaticResource BodyTextStyle}" FontSize="13" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Grid>

                        <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,4,0,16"/>

                        <TextBlock Text="CẬP NHẬT TIẾN ĐỘ" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="70"/>
                            </Grid.ColumnDefinitions>
                            <Slider Grid.Column="0" Value="65" Maximum="100" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="65%" Style="{StaticResource DefaultTextBoxStyle}" TextAlignment="Center" Margin="12,0,0,0" IsReadOnly="True"/>
                        </Grid>

                        <Border BorderBrush="{StaticResource WarningBrush}" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,16" Background="#FFFBEB">
                            <StackPanel>
                                <TextBlock Text="⚠️ Công việc đang chờ nghiệm thu" FontWeight="Bold" FontSize="13" Foreground="#B45309"/>
                                <TextBlock Text="Thành viên đã bấm gửi yêu cầu duyệt lúc 14:20 hôm nay." Style="{StaticResource BodyTextStyle}" FontSize="12" Margin="0,2,0,10"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Content="✔ Phê duyệt" Style="{StaticResource PrimaryButtonStyle}" Background="{StaticResource SuccessBrush}" Height="32" FontSize="12" Margin="0,0,6,0"/>
                                    <Button Grid.Column="1" Content="Yêu cầu sửa lại" Style="{StaticResource DangerButtonStyle}" Height="32" FontSize="12" Margin="6,0,0,0"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="MÔ TẢ CHI TIẾT" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                        <TextBlock Style="{StaticResource BodyTextStyle}" LineHeight="20" TextWrapping="Wrap" Margin="0,0,0,16">
                            - Thiết kế các bảng: Tasks, Projects, TaskComments, TaskHistory.<LineBreak/>
                            - Liên kết khóa ngoại đúng theo mô hình quan hệ đã chốt hôm thứ 3.<LineBreak/>
                            - Viết script SQL khởi tạo sẵn 5 dòng dữ liệu mẫu cho mỗi bảng.
                        </TextBlock>

                        <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,0,0,16"/>

                        <TextBlock Text="THẢO LUẬN (2)" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"/>

                        <Border Background="{StaticResource BackgroundBrush}" CornerRadius="6" Padding="10" Margin="0,0,0,8">
                            <StackPanel>
                                <Grid Margin="0,0,0,4">
                                    <TextBlock Text="Đặng Ngọc Đức" FontWeight="Bold" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="10:15 sáng" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Right"/>
                                </Grid>
                                <TextBlock Text="Đại nhớ để trường Progress là kiểu Int từ 0 đến 100 nhé đừng để Decimal." Style="{StaticResource BodyTextStyle}" FontSize="12" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Height="38" Tag="Viết bình luận..." Style="{StaticResource DefaultTextBoxStyle}" Margin="0,0,8,0"/>
                            <Button Grid.Column="1" Content="Gửi" Style="{StaticResource PrimaryButtonStyle}" Width="60" Height="38" Padding="0"/>
                        </Grid>

                    </StackPanel>
                </ScrollViewer>
            </Border>

        </Grid>
    </Grid>
</UserControl>
