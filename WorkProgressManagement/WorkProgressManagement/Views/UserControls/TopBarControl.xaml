<UserControl x:Class="WorkProgressManagement.Views.UserControls.TopBarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WorkProgressManagement.Views.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="20,10">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="180"/>
        </Grid.ColumnDefinitions>

        <!-- Page Title -->
        <TextBlock Grid.Column="0"
               Text="Dashboard"
               Style="{StaticResource TitleTextStyle}"
               VerticalAlignment="Center"/>

        <!-- Search -->
        <TextBox Grid.Column="1"
             Style="{StaticResource DefaultTextBoxStyle}"
             Text="🔍 Search..."
             Margin="15,0"/>

        <!-- User -->
        <StackPanel Grid.Column="2"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                VerticalAlignment="Center">

            <TextBlock Text="👤"
                   FontSize="22"
                   Margin="0,0,8,0"/>

            <StackPanel>

                <TextBlock Text="Administrator"
                       Style="{StaticResource SubtitleTextStyle}"/>

                <TextBlock Text="Project Manager"
                       Style="{StaticResource BodyTextStyle}"/>

            </StackPanel>

        </StackPanel>

    </Grid>
</UserControl>
