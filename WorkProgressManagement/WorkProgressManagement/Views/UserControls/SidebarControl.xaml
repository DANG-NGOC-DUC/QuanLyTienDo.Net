<UserControl x:Class="WorkProgressManagement.Views.UserControls.SidebarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WorkProgressManagement.Views.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="{StaticResource CardBrush}">

        <Grid.RowDefinitions>
            <RowDefinition Height="90"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <!-- Logo -->
        <StackPanel Grid.Row="0"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">

            <TextBlock Text="📋"
                   FontSize="32"
                   HorizontalAlignment="Center"/>
            <TextBlock Text="Work Progress"
                   Style="{StaticResource SubtitleTextStyle}"/>

            <TextBlock Text="Management"
                   Style="{StaticResource BodyTextStyle}"
                   HorizontalAlignment="Center"/>

        </StackPanel>

        <!-- Menu -->
        <StackPanel Grid.Row="1"
                Margin="12">

            <Button Content="🏠 Dashboard"
                Style="{StaticResource SecondaryButtonStyle}"
                Margin="0,5"/>

            <Button Content="👤 Người dùng"
                Style="{StaticResource SecondaryButtonStyle}"
                Margin="0,5"/>

            <Button Content="📁 Dự án"
                Style="{StaticResource SecondaryButtonStyle}"
                Margin="0,5"/>

            <Button Content="✅ Công việc"
                Style="{StaticResource SecondaryButtonStyle}"
                Margin="0,5"/>

            <Button Content="📊 Báo cáo"
                Style="{StaticResource SecondaryButtonStyle}"
                Margin="0,5"/>

            <Button Content="👤 Hồ sơ"
                Style="{StaticResource SecondaryButtonStyle}"
                Margin="0,5"/>

        </StackPanel>

        <!-- Logout -->
        <Button Grid.Row="2"
            Content="🚪 Đăng xuất"
            Style="{StaticResource DangerButtonStyle}"
            Margin="12"/>

    </Grid>
</UserControl>
